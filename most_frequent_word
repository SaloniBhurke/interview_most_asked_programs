import java.util.*;
import java.util.stream.Collectors;

class Main {
    public static void main(String[] args) {
        
        List<String> words = Arrays.asList("apple","apple","banana","orange","banana","banana");
        
        Map<String, Long> wordCount = words.stream().collect(Collectors.groupingBy(w -> w, Collectors.counting()));
        
        
        System.out.println(wordCount);
        
        String mostFrequent = wordCount.entrySet().stream().max(Map.Entry.comparingByValue()).get().getKey();
        
        System.out.println(mostFrequent);

    }
}
